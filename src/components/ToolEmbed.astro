---
import type { EmbedEntry } from '../scripts/embeds-schema';
import ToolCard from './ToolCard.astro';

export interface Props {
  entry: EmbedEntry;
}

const { entry } = Astro.props;
---

{
  entry.embeddable ? (
    <figure class="tool-embed">
      <div class="tool-embed__frame">
        <iframe
          src={entry.url}
          title={`Outil intégré : ${entry.nom}`}
          loading="lazy"
          sandbox="allow-scripts allow-same-origin allow-popups"
        />
      </div>
      <figcaption class="tool-embed__caption">
        <span>{entry.nom}</span>
        <a href={entry.url} target="_blank" rel="noopener noreferrer">
          Ouvrir dans un nouvel onglet
        </a>
      </figcaption>
    </figure>
  ) : (
    <ToolCard
      nom={entry.nom}
      description={entry.description}
      url={entry.url}
      image={entry.image}
      tags={entry.tags}
    />
  )
}

<style>
  .tool-embed {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
  }

  .tool-embed__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-alt, #261f35);
    border: 1px solid var(--color-border, #3a3150);
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
  }

  .tool-embed__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .tool-embed__caption {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2, 0.5rem);
    font-size: 0.9rem;
    color: var(--color-text-muted, #b3a9c7);
  }
</style>

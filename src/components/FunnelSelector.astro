---
import type { JeuMues } from '../scripts/mues-schema';

export interface Props {
  jeu: JeuMues;
}

const { jeu } = Astro.props;
const jeuJson = JSON.stringify(jeu);
const total = jeu.questions.length;
const totalMues = jeu.mues.length;
---

<section class="funnel" aria-labelledby="funnel-title" data-jeu={jeuJson}>
  <h2 id="funnel-title" class="visually-hidden">Sélecteur — {jeu.jeu}</h2>

  <div class="funnel__meta">
    <p class="funnel__progress" aria-live="polite" data-progress>
      Étape 1 / {total}
    </p>
    <button
      type="button"
      class="funnel__count-btn"
      data-count-btn
      aria-expanded="false"
      aria-controls="funnel-mues-panel"
    >
      <span data-count-num>{totalMues}</span> {jeu.jeu.toLowerCase().includes('monsterhearts') ? 'mues' : 'playbooks'}
    </button>
  </div>

  <div class="funnel__mues-panel" id="funnel-mues-panel" data-mues-panel hidden>
    <p class="funnel__mues-panel-hint">Les <span class="funnel__mues-panel-eliminated">barrées</span> ne peuvent plus arriver en tête, vu tes réponses.</p>
    <ul class="funnel__mues-list" data-mues-list></ul>
  </div>

  <!-- Écran question -->
  <div class="funnel__question" data-question-screen>
    <p class="funnel__question-theme" data-question-theme hidden></p>
    <h3 class="funnel__question-text" data-question-text></h3>
    <ul class="funnel__options" role="group" aria-label="Réponses possibles" data-options></ul>
  </div>

  <!-- Écran résultat -->
  <div class="funnel__result" data-result-screen hidden>
    <h3>Notre recommandation</h3>
    <div data-result-main></div>
    <div data-result-alts></div>
  </div>

  <div class="funnel__nav">
    <button type="button" data-prev disabled>Précédent</button>
    <button type="button" data-restart hidden>Recommencer</button>
  </div>
</section>

<!--
  is:global est nécessaire : options, cartes de résultat et liste des mues sont
  générées en JS (createElement / innerHTML) et ne portent donc pas le marqueur
  de portée data-astro-cid-* que Astro exige sur les sélecteurs scopés. Tous les
  sélecteurs sont préfixés `.funnel` (classe unique au composant) : aucune fuite.
-->
<style is:global>
  .funnel {
    max-width: 40rem;
    margin: 0 auto;
  }

  .funnel__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .funnel__progress {
    margin: 0;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .funnel__count-btn {
    font: inherit;
    font-size: 0.9rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface-alt);
    color: var(--color-accent-strong);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .funnel__count-btn:hover,
  .funnel__count-btn:focus-visible {
    background: var(--color-border);
    border-color: var(--color-accent-strong);
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
  .funnel__count-btn[aria-expanded='true'] {
    background: var(--color-surface-alt);
    border-color: var(--color-accent-strong);
  }

  .funnel__mues-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md, 12px);
    padding: 1rem;
    margin-bottom: 1.25rem;
  }
  .funnel__mues-panel-hint {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .funnel__mues-panel-eliminated {
    text-decoration: line-through;
    opacity: 0.55;
  }
  .funnel__mues-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .funnel__mues-list li {
    font-size: 0.9rem;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm, 6px);
    background: var(--color-surface-alt);
    color: var(--color-text);
  }
  .funnel__mues-list li.is-eliminated {
    text-decoration: line-through;
    opacity: 0.4;
    color: var(--color-text-muted);
  }

  .funnel__question-theme {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-strong);
  }
  .funnel__question-text {
    margin: 0 0 1rem;
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .funnel__options {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .funnel__options button {
    width: 100%;
    text-align: left;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 8px);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    transition: border-color 0.15s, background 0.15s;
  }
  .funnel__options button:hover,
  .funnel__options button:focus-visible {
    border-color: var(--color-accent-strong);
    background: var(--color-surface-alt);
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
  }
  .funnel__options button[aria-pressed='true'] {
    border-color: var(--color-accent-strong);
    background: var(--color-surface-alt);
    font-weight: 600;
  }

  .funnel__nav {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
  }
  .funnel__nav button {
    padding: 0.5rem 1rem;
    font: inherit;
    cursor: pointer;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 6px);
    background: var(--color-surface-alt);
    color: var(--color-text);
    transition: background 0.15s;
  }
  .funnel__nav button:hover:not(:disabled) {
    background: var(--color-border);
  }
  .funnel__nav button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .funnel__result article {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm, 8px);
    padding: 1rem;
    margin: 0.75rem 0;
    background: var(--color-surface);
  }
  .funnel__result .is-main {
    border-color: var(--color-accent-strong);
    border-width: 2px;
  }
  .funnel__badge {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent-strong);
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .funnel .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  import {
    createFunnelState,
    setReponse,
    nextStep,
    previousStep,
    isComplete,
    resetFunnel,
    topRecommendations,
    funnelEligibility,
    type FunnelState,
  } from '../scripts/funnel';
  import { scoreMues, type JeuMues, type Mue } from '../scripts/mues-schema';
  import { saveData } from '../scripts/storage';

  /**
   * Mues encore en lice vs éliminées, via l'entonnoir éliminatoire MONOTONE
   * (une mue est éliminée dès qu'elle ne peut plus rattraper la tête). Le
   * nombre d'éligibles ne fait donc que décroître au fil des réponses.
   */
  function computeEligible(
    jeu: JeuMues,
    reponses: Record<string, string>,
  ): { eligible: Mue[]; eliminated: Mue[] } {
    const elig = funnelEligibility(jeu, reponses);
    return {
      eligible: elig.filter((e) => e.eligible).map((e) => e.mue),
      eliminated: elig.filter((e) => !e.eligible).map((e) => e.mue),
    };
  }

  function initFunnel(root: HTMLElement): void {
    const raw = root.dataset.jeu;
    if (!raw) return;
    const jeu = JSON.parse(raw) as JeuMues;
    const total = jeu.questions.length;

    const progress = root.querySelector<HTMLElement>('[data-progress]')!;
    const countBtn = root.querySelector<HTMLButtonElement>('[data-count-btn]')!;
    const countNum = root.querySelector<HTMLElement>('[data-count-num]')!;
    const muesPanel = root.querySelector<HTMLElement>('[data-mues-panel]')!;
    const muesList = root.querySelector<HTMLElement>('[data-mues-list]')!;
    const questionScreen = root.querySelector<HTMLElement>('[data-question-screen]')!;
    const questionText = root.querySelector<HTMLElement>('[data-question-text]')!;
    const optionsList = root.querySelector<HTMLElement>('[data-options]')!;
    const resultScreen = root.querySelector<HTMLElement>('[data-result-screen]')!;
    const resultMain = root.querySelector<HTMLElement>('[data-result-main]')!;
    const resultAlts = root.querySelector<HTMLElement>('[data-result-alts]')!;
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]')!;
    const restartBtn = root.querySelector<HTMLButtonElement>('[data-restart]')!;

    let state: FunnelState = createFunnelState();

    function escapeHtml(value: string): string {
      const div = document.createElement('div');
      div.textContent = value;
      return div.innerHTML;
    }

    function updateCount(): void {
      const { eligible, eliminated } = computeEligible(jeu, state.reponses);
      countNum.textContent = `${eligible.length} / ${jeu.mues.length}`;

      muesList.innerHTML = '';
      for (const mue of jeu.mues) {
        const li = document.createElement('li');
        li.textContent = mue.nom;
        if (eliminated.some((e) => e.id === mue.id)) {
          li.classList.add('is-eliminated');
        }
        muesList.appendChild(li);
      }
    }

    countBtn.addEventListener('click', () => {
      const expanded = countBtn.getAttribute('aria-expanded') === 'true';
      countBtn.setAttribute('aria-expanded', String(!expanded));
      muesPanel.hidden = expanded;
      if (!expanded) updateCount();
    });

    function renderMueCard(mue: Mue, isMain: boolean): string {
      const lien = mue.lienOfficiel
        ? `<p><a href="${escapeHtml(mue.lienOfficiel)}" rel="noopener noreferrer">Fiche officielle</a></p>`
        : '';
      const role = isMain ? '<p class="funnel__badge">Recommandation principale</p>' : '';
      return `<article class="${isMain ? 'is-main' : 'is-alt'}">
        ${role}
        <h4>${escapeHtml(mue.nom)}</h4>
        <p>${escapeHtml(mue.resume)}</p>
        ${lien}
      </article>`;
    }

    function renderResult(): void {
      const scored = scoreMues(jeu, state.reponses);
      const recos = topRecommendations(scored, 3);

      questionScreen.hidden = true;
      resultScreen.hidden = false;
      restartBtn.hidden = false;
      prevBtn.disabled = false;
      progress.textContent = 'Résultat';
      updateCount();

      if (recos.length === 0) {
        resultMain.innerHTML = '<p>Aucune recommandation disponible.</p>';
        resultAlts.innerHTML = '';
        return;
      }

      resultMain.innerHTML = renderMueCard(recos[0].mue, true);
      const alts = recos.slice(1);
      resultAlts.innerHTML = alts.length
        ? `<h4>Alternatives proches</h4>${alts.map((r) => renderMueCard(r.mue, false)).join('')}`
        : '';

      try {
        saveData(`funnel:${jeu.jeu}:last`, {
          reponses: state.reponses,
          recommandations: recos.map((r) => r.mue.id),
        });
      } catch {
        /* localStorage indisponible */
      }
    }

    function renderQuestion(): void {
      const question = jeu.questions[state.index];
      questionScreen.hidden = false;
      resultScreen.hidden = true;
      restartBtn.hidden = true;
      prevBtn.disabled = state.index === 0;
      progress.textContent = `Étape ${state.index + 1} / ${total}`;
      questionText.textContent = question.texte;
      const themeEl = root.querySelector<HTMLElement>('[data-question-theme]');
      if (themeEl) {
        const theme = (question as { theme?: string }).theme ?? '';
        themeEl.textContent = theme;
        themeEl.hidden = theme.length === 0;
      }

      updateCount();
      if (!muesPanel.hidden) updateCount();

      optionsList.innerHTML = '';
      const chosen = state.reponses[question.id];
      for (const option of question.options) {
        const li = document.createElement('li');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = option.texte;
        btn.setAttribute('aria-pressed', String(chosen === option.id));
        btn.addEventListener('click', () => {
          state = setReponse(state, question.id, option.id);
          state = nextStep(state, total);
          render();
        });
        li.appendChild(btn);
        optionsList.appendChild(li);
      }
    }

    function render(): void {
      if (isComplete(state, total)) {
        renderResult();
      } else {
        renderQuestion();
      }
    }

    prevBtn.addEventListener('click', () => {
      if (isComplete(state, total)) {
        state = { ...state, index: total - 1 };
      } else {
        state = previousStep(state);
      }
      render();
    });

    restartBtn.addEventListener('click', () => {
      state = resetFunnel();
      render();
    });

    render();
  }

  for (const root of document.querySelectorAll<HTMLElement>('.funnel[data-jeu]')) {
    initFunnel(root);
  }
</script>

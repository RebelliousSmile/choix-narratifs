---
export interface Props {
  nom: string;
  description: string;
  url: string;
  image?: string;
  tags?: string[];
}

const { nom, description, url, image, tags = [] } = Astro.props;
---

<article class="tool-card">
  {image && <img class="tool-card__img" src={image} alt="" loading="lazy" />}
  <div class="tool-card__body">
    <h3 class="tool-card__title">{nom}</h3>
    <p class="tool-card__desc">{description}</p>
    {
      tags.length > 0 && (
        <ul class="tool-card__tags" aria-label="Étiquettes">
          {tags.map((tag) => (
            <li class="tool-card__tag">{tag}</li>
          ))}
        </ul>
      )
    }
    <a class="tool-card__cta" href={url} target="_blank" rel="noopener noreferrer">
      Ouvrir l'outil
      <span class="visually-hidden"> (nouvel onglet)</span>
    </a>
  </div>
</article>

<style>
  .tool-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-surface, #1e1929);
    border: 1px solid var(--color-border, #3a3150);
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
  }

  .tool-card__img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--color-surface-alt, #261f35);
  }

  .tool-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 0.5rem);
    padding: var(--space-4, 1.5rem);
    flex: 1;
  }

  .tool-card__title {
    margin: 0;
    font-size: 1.1rem;
  }

  .tool-card__desc {
    margin: 0;
    color: var(--color-text-muted, #b3a9c7);
    font-size: 0.95rem;
  }

  .tool-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1, 0.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tool-card__tag {
    font-size: 0.75rem;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: var(--color-surface-alt, #261f35);
    color: var(--color-text-muted, #b3a9c7);
    border: 1px solid var(--color-border, #3a3150);
  }

  .tool-card__cta {
    margin-top: auto;
    align-self: flex-start;
    display: inline-block;
    padding: var(--space-2, 0.5rem) var(--space-3, 1rem);
    background: var(--color-accent, #c45a92);
    color: #fff;
    text-decoration: none;
    border-radius: var(--radius-sm, 6px);
    font-weight: 600;
  }

  .tool-card__cta:hover,
  .tool-card__cta:focus-visible {
    background: var(--color-accent-strong, #e07bb0);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

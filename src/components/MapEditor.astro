---
import type { PaletteItem, PlacedItem } from '../scripts/map-state';

export interface Props {
  tool: string;
  palette: PaletteItem[];
  presets?: PlacedItem[];
  background?: string;
}

const { tool, palette, presets = [], background } = Astro.props;

const config = JSON.stringify({ tool, palette, presets, background });
---

<section class="map-editor" aria-label={`Éditeur de carte (${tool})`} data-config={config}>
  <div class="map-editor__toolbar" role="toolbar" aria-label="Outils de la carte">
    <div class="map-editor__palette" data-palette aria-label="Palette d'éléments">
      {
        palette.map((item) => (
          <button
            type="button"
            class="map-editor__palette-item"
            data-palette-id={item.id}
            style={item.color ? `--swatch:${item.color}` : undefined}
          >
            {item.label}
          </button>
        ))
      }
    </div>
    <div class="map-editor__actions">
      <button type="button" data-action="new">Nouveau</button>
      <button type="button" data-action="save">Sauvegarder</button>
      <button type="button" data-action="load">Charger</button>
      <button type="button" data-action="export-png">Exporter PNG</button>
      <button type="button" data-action="export-json">Exporter JSON</button>
      <button type="button" data-action="import-json">Importer JSON</button>
      <button type="button" data-action="delete">Supprimer</button>
    </div>
  </div>

  <div class="map-editor__canvas" data-canvas tabindex="0" aria-label="Zone d'édition de la carte"></div>

  <input type="file" accept="application/json" data-import-input hidden />
</section>

<style>
  .map-editor {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }
  .map-editor__toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-start;
  }
  .map-editor__palette,
  .map-editor__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .map-editor button {
    font: inherit;
    padding: 0.4rem 0.8rem;
    border: 1px solid #555;
    border-radius: 6px;
    background: #2a2440;
    color: #ece8f5;
    cursor: pointer;
  }
  .map-editor button:hover,
  .map-editor button:focus-visible {
    background: #3a3460;
    border-color: #ece8f5;
    outline: 2px solid #ffd34d;
    outline-offset: 1px;
  }
  .map-editor__palette-item {
    border-left: 6px solid var(--swatch, #4477aa);
  }
  .map-editor__canvas {
    width: 100%;
    height: 60vh;
    min-height: 400px;
    border: 1px solid #555;
    border-radius: 8px;
    overflow: hidden;
    background: #fafafa;
    position: relative;
  }
  .map-editor__canvas:focus-visible {
    outline: 2px solid #555;
    outline-offset: 2px;
  }
</style>

<script>
  // konva ne doit JAMAIS être importé côté serveur : tout est dynamique ici.
  import type { MapEditor } from '../scripts/map-editor';
  import type { MapState, PaletteItem, PlacedItem } from '../scripts/map-state';

  interface MapConfig {
    tool: string;
    palette: PaletteItem[];
    presets: PlacedItem[];
    background?: string;
  }

  async function initEditor(root: HTMLElement): Promise<void> {
    const raw = root.dataset.config;
    if (!raw) return;

    let config: MapConfig;
    try {
      config = JSON.parse(raw) as MapConfig;
    } catch {
      console.error('[MapEditor] Impossible de parser la config JSON');
      return;
    }

    const canvas = root.querySelector<HTMLElement>('[data-canvas]');
    if (!canvas) return;

    // Attendre que le layout soit stabilisé avant d'initialiser Konva.
    await new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));

    let createMapEditor: (typeof import('../scripts/map-editor'))['createMapEditor'];
    let storage: typeof import('../scripts/storage');
    try {
      const mod = await import('../scripts/map-editor');
      createMapEditor = mod.createMapEditor;
      storage = await import('../scripts/storage');
    } catch (err) {
      console.error('[MapEditor] Erreur de chargement du module:', err);
      canvas.textContent = 'Erreur de chargement de l\'éditeur. Voir la console.';
      return;
    }

    const editor: MapEditor = createMapEditor(canvas, {
      palette: config.palette,
      presets: config.presets,
      background: config.background,
    });

    // Palette : clic pour ajouter au centre, drag&drop pour positionner.
    root.querySelectorAll<HTMLButtonElement>('[data-palette-id]').forEach((btn) => {
      const paletteId = btn.dataset.paletteId!;
      btn.draggable = true;
      btn.addEventListener('click', () => {
        editor.addFromPalette(paletteId, canvas.clientWidth / 2, canvas.clientHeight / 2);
      });
      btn.addEventListener('dragstart', (e) => {
        e.dataTransfer?.setData('text/palette-id', paletteId);
      });
    });

    canvas.addEventListener('dragover', (e) => e.preventDefault());
    canvas.addEventListener('drop', (e) => {
      e.preventDefault();
      const paletteId = e.dataTransfer?.getData('text/palette-id');
      if (!paletteId) return;
      const rect = canvas.getBoundingClientRect();
      editor.addFromPalette(paletteId, e.clientX - rect.left, e.clientY - rect.top);
    });

    function action(name: string, fn: () => void): void {
      root.querySelector<HTMLButtonElement>(`[data-action="${name}"]`)?.addEventListener('click', fn);
    }

    const storageKey = `map:${config.tool}`;

    action('new', () => editor.loadState({ schemaVersion: 1, items: [] }));
    action('delete', () => editor.removeSelected());

    action('save', () => {
      storage.saveData(storageKey, editor.getState());
    });

    action('load', () => {
      const loaded = storage.loadData<MapState>(storageKey);
      if (loaded) editor.loadState(loaded);
    });

    action('export-png', () => {
      const url = editor.exportPNG();
      const a = document.createElement('a');
      a.href = url;
      a.download = `${config.tool}.png`;
      a.click();
    });

    action('export-json', () => {
      const blob = storage.exportData(editor.getState());
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `${config.tool}.json`;
      a.click();
      URL.revokeObjectURL(url);
    });

    // Permet à la page hôte de charger un état (ex. ébauche générée) via
    // un CustomEvent 'map-editor:load-state' dispatché sur le conteneur.
    root.addEventListener('map-editor:load-state', (event) => {
      const detail = (event as CustomEvent<MapState>).detail;
      if (detail && Array.isArray(detail.items)) {
        editor.loadState(detail);
      }
    });

    const input = root.querySelector<HTMLInputElement>('[data-import-input]');
    action('import-json', () => input?.click());
    input?.addEventListener('change', async () => {
      const file = input.files?.[0];
      if (!file) return;
      try {
        const text = await file.text();
        const data = JSON.parse(text) as MapState;
        editor.loadState(data);
      } catch (err) {
        alert(err instanceof Error ? err.message : 'Import impossible : fichier JSON invalide.');
      }
      input.value = '';
    });
  }

  for (const root of document.querySelectorAll<HTMLElement>('.map-editor[data-config]')) {
    initEditor(root).catch((err) => console.error('[MapEditor] Erreur init:', err));
  }
</script>

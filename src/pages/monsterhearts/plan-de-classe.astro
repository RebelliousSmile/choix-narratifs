---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MapEditor from '../../components/MapEditor.astro';
import { generateClassroom, CLASSROOM_DESK_PALETTE_ID } from '../../scripts/classroom';
import type { PaletteItem } from '../../scripts/map-state';

const palette: PaletteItem[] = [
  // ── Pupitre (taille et sens configurables dans le panneau d'édition) ──
  { id: CLASSROOM_DESK_PALETTE_ID, label: 'Pupitre', color: '#4477aa', shape: 'rect', widthUnits: 2, heightUnits: 2 },
  // ── Mobilier ──
  { id: 'bureau-adulte', label: 'Bureau adulte', color: '#aa7744', shape: 'rect', widthUnits: 4, heightUnits: 2 },
  { id: 'porte',         label: 'Porte',         color: '#77aa55', shape: 'rect', widthUnits: 2, heightUnits: 1 },
  { id: 'fenetre',       label: 'Fenêtre',       color: '#55aacc', shape: 'rect', widthUnits: 4, heightUnits: 1 },
  // ── Humains — ascendants autorisés (paletteId commence par "humain-") ──
  { id: 'humain-eleve',  label: 'Élève / PNJ',  color: '#c45a92', shape: 'circle' },
  { id: 'humain-adulte', label: 'Adulte',        color: '#e07bb0', shape: 'circle' },
];

const presets = generateClassroom(4, 5, 900, 636);
---

<BaseLayout
  title="Plan de classe — Monsterhearts"
  description="Représentez la disposition de la classe et les groupes d'influence. Pupitres simples, doubles ou triples, liens d'ascendant entre élèves."
>
  <article class="outil">
    <header class="outil__header">
      <h1>Plan de classe — Monsterhearts</h1>
      <p class="outil__intro">
        Posez les pupitres, nommez vos élèves, assignez des groupes d'influence et
        tracez des ascendants. Sélectionnez un élément pour en modifier les options.
      </p>
    </header>

    <MapEditor tool="plan-de-classe" palette={palette} presets={presets} />

    <footer class="outil__footer">
      <p><a href="/jeux">&larr; Retour aux outils Monsterhearts</a></p>
    </footer>
  </article>

  <style>
    .outil__header { max-width: 44rem; margin-bottom: var(--space-4); }
    .outil__intro  { color: var(--color-text-muted); font-size: 1.05rem; }
    .outil__footer { margin-top: var(--space-5); color: var(--color-text-muted); }
  </style>

  <script>
    import { generateClassroom } from '../../scripts/classroom';
    import { MAP_SCHEMA_VERSION } from '../../scripts/map-state';

    // L'éditeur demande une génération de grille via cet événement
    document.addEventListener('map-editor:request-generate', (event) => {
      const { rows, cols, canvasW, canvasH } = (event as CustomEvent).detail as {
        rows: number; cols: number; canvasW: number; canvasH: number;
      };
      const items = generateClassroom(rows, cols, canvasW, canvasH);
      const editorRoot = document.querySelector<HTMLElement>('.map-editor[data-config]');
      editorRoot?.dispatchEvent(
        new CustomEvent('map-editor:load-state', {
          detail: { schemaVersion: MAP_SCHEMA_VERSION, items, groups: [], relations: [] },
        }),
      );
    });
  </script>
</BaseLayout>
